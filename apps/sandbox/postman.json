                "guilds",
                "{{guildId}}",
                "bans"
              ]
            },
            "description": "Get list of all banned users in a guild"
          },
          "response": []
        },
        {
          "name": "Get Ban Info",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{apiKey}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/guilds/{{guildId}}/bans/{{userId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "guilds",
                "{{guildId}}",
                "bans",
                "{{userId}}"
              ]
            },
            "description": "Get ban information for a specific user"
          },
          "response": []
        },
        {
          "name": "Ban User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{apiKey}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"reason\": \"Violating community guidelines\",\n  \"deleteMessageDays\": 7\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/guilds/{{guildId}}/bans",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "guilds",
                "{{guildId}}",
                "bans"
              ]
            },
            "description": "Ban a user from the guild"
          },
          "response": []
        },
        {
          "name": "Unban User",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{apiKey}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/guilds/{{guildId}}/bans/{{userId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "guilds",
                "{{guildId}}",
                "bans",
                "{{userId}}"
              ]
            },
            "description": "Remove ban from a user"
          },
          "response": []
        }
      ]
    },
