{
  "info": {
    "name": "Spraxium HTTP API",
    "description": "Complete API collection for Spraxium Discord bot HTTP module sandbox",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Guild Management",
      "item": [
        {
          "name": "Get Guild Info",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{apiKey}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/guilds/{{guildId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "guilds",
                "{{guildId}}"
              ]
            },
            "description": "Retrieve guild information"
          },
          "response": []
        },
        {
          "name": "Get Guild Stats",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{apiKey}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/guilds/{{guildId}}/stats",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "guilds",
                "{{guildId}}",
                "stats"
              ]
            },
            "description": "Get guild statistics (member count, boost level, channels, roles, emojis)"
          },
          "response": []
        },
        {
