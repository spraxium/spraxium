                "{{baseUrl}}"
              ],
              "path": [
                "guilds",
                "{{guildId}}",
                "channels"
              ]
            },
            "description": "Get all channels in a guild"
          },
          "response": []
        },
        {
          "name": "Get Guild Bans",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{apiKey}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/guilds/{{guildId}}/bans",
