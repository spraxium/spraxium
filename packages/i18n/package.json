{
  "name": "@spraxium/i18n",
  "version": "0.1.3",
  "private": false,
  "description": "Internationalization module with variable interpolation, plural resolution and Discord locale support",
  "keywords": [
    "discord",
    "discord.js",
    "discord-bot",
    "spraxium",
    "typescript",
    "i18n",
    "internationalization",
    "localization",
    "l10n",
    "translations",
    "discord-locale",
    "plural",
    "interpolation",
    "bot-framework",
    "multi-language"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@spraxium/logger": "workspace:*",
    "discord.js": "^14.26.3",
    "reflect-metadata": "^0.2.2"
  },
  "peerDependencies": {
    "@spraxium/common": "workspace:*",
    "@spraxium/components": "workspace:*",
    "@spraxium/core": "workspace:*",
    "@spraxium/logger": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@spraxium/components": {
      "optional": true
    }
  },
  "devDependencies": {
    "@spraxium/common": "workspace:*",
    "@spraxium/components": "workspace:*",
    "@spraxium/core": "workspace:*",
    "@spraxium/logger": "workspace:*",
    "@types/node": "^22.13.0",
    "tsdown": "^0.12.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "files": ["dist"],
  "license": "Apache-2.0"
}
