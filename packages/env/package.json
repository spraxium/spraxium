{
  "name": "@spraxium/env",
  "version": "0.1.2",
  "private": false,
  "description": "Typed environment variable validation with class decorators and clear startup errors",
  "keywords": [
    "discord",
    "discord-bot",
    "spraxium",
    "typescript",
    "decorators",
    "environment-variables",
    "env-validation",
    "dotenv",
    "configuration",
    "class-validator",
    "bot-framework",
    "startup-validation",
    "type-safe-env"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "chalk": "^5.4.0",
    "cli-table3": "^0.6.5",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "tsdown": "^0.12.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "files": ["dist"],
  "license": "Apache-2.0"
}
