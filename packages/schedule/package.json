{
  "name": "@spraxium/schedule",
  "version": "0.2.1",
  "private": false,
  "description": "Cron-based job scheduler with optional Redis driver for distributed and sharded environments",
  "keywords": [
    "discord",
    "discord.js",
    "discord-bot",
    "spraxium",
    "typescript",
    "decorators",
    "cron",
    "scheduler",
    "cron-job",
    "task-scheduling",
    "redis",
    "distributed",
    "sharding",
    "bot-framework",
    "jobs"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "cron-parser": "^4.9.0",
    "discord.js": "^14.26.4",
    "reflect-metadata": "^0.2.2"
  },
  "peerDependencies": {
    "@spraxium/common": "workspace:*",
    "@spraxium/core": "workspace:*",
    "@spraxium/logger": "workspace:*",
    "ioredis": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "ioredis": {
      "optional": true
    }
  },
  "devDependencies": {
    "@spraxium/common": "workspace:*",
    "@spraxium/core": "workspace:*",
    "@spraxium/logger": "workspace:*",
    "@types/node": "^22.13.0",
    "tsdown": "^0.12.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "files": [
    "dist"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/spraxium/spraxium",
    "directory": "packages/schedule"
  }
}
