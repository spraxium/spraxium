{
  "name": "@spraxium/signal",
  "version": "0.2.2",
  "private": false,
  "description": "Async unidirectional event signal system dispatched through Discord webhooks with schema validation",
  "keywords": [
    "discord",
    "discord.js",
    "discord-bot",
    "spraxium",
    "typescript",
    "decorators",
    "signals",
    "event-bus",
    "pub-sub",
    "webhook",
    "async-events",
    "schema-validation",
    "bot-framework",
    "unidirectional"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/"
  },
  "dependencies": {
    "@spraxium/common": "workspace:*",
    "@spraxium/core": "workspace:*",
    "@spraxium/logger": "workspace:*",
    "discord.js": "^14.26.4",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsdown": "^0.12.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "files": ["dist"],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/spraxium/spraxium",
    "directory": "packages/signal"
  }
}
