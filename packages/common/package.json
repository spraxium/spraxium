{
  "name": "@spraxium/common",
  "version": "0.2.1",
  "private": false,
  "description": "Shared decorators, interfaces and types used across the Spraxium framework",
  "keywords": [
    "discord",
    "discord.js",
    "discord-bot",
    "spraxium",
    "typescript",
    "decorators",
    "dependency-injection",
    "reflect-metadata",
    "interfaces",
    "metadata",
    "bot-framework",
    "guards",
    "slash-commands",
    "prefix-commands"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@spraxium/logger": "workspace:*",
    "reflect-metadata": "^0.2.2"
  },
  "peerDependencies": {
    "discord.js": "^14.26.4"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "discord.js": "^14.26.4",
    "tsdown": "^0.12.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "files": [
    "dist"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/spraxium/spraxium",
    "directory": "packages/common"
  }
