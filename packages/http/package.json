{
  "name": "@spraxium/http",
  "version": "0.1.3",
  "private": false,
  "description": "HTTP bridge layer for Spraxium bots — exposes bot state over a secured REST API",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "hono": "^4.7.0",
    "reflect-metadata": "^0.2.2",
    "zod": "^3.22.0"
  },
  "peerDependencies": {
    "@spraxium/common": "*",
    "@spraxium/core": "*",
    "discord.js": "^14.26.3"
  },
  "devDependencies": {
    "@spraxium/common": "^0.1.1",
    "@spraxium/core": "^0.1.1",
    "@types/node": "^22.0.0",
    "tsdown": "^0.12.0",
    "typescript": "^5.7.0"
  },
  "files": ["dist"],
  "license": "Apache-2.0",
  "type": "module"
}
