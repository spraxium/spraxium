{
  "name": "@spraxium/logger",
  "version": "0.1.0",
  "private": false,
  "description": "Centralized, zero-dependency logging system for the Spraxium ecosystem",
  "keywords": ["discord", "discord-bot", "spraxium", "typescript", "logger", "logging", "bot-framework"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
