    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "cli-table3": "^0.6.5"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "tsdown": "^0.12.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "files": ["dist"],
  "license": "Apache-2.0"
}
