{
  "name": "@spraxium/components",
  "version": "0.1.3",
  "private": false,
  "description": "Decorator-based Discord UI components system for buttons, select menus, modals and embeds",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch"
  },
  "dependencies": {
    "@discordjs/builders": "^1.14.1",
    "discord.js": "^14.26.3",
    "reflect-metadata": "^0.2.2"
  },
  "peerDependencies": {
    "@spraxium/common": "workspace:*",
    "@spraxium/core": "workspace:*",
    "better-sqlite3": "\u003e=9",
    "ioredis": "\u003e=5"
  },
  "peerDependenciesMeta": {
    "@spraxium/core": {
      "optional": true
    },
    "better-sqlite3": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    }
  },
  "devDependencies": {
    "@spraxium/common": "workspace:*",
    "@spraxium/core": "workspace:*",
    "@types/node": "^22.13.0",
    "tsdown": "^0.12.0",
    "typescript": "^5.7.0"
  },
  "files": ["dist"],
  "license": "Apache-2.0"
}
