{
  "name": "@spraxium/webhook",
  "version": "0.1.0",
  "private": false,
  "description": "Decorator-based Discord webhook management for Spraxium bots with a rich send API",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/"
  },
  "dependencies": {
    "chalk": "^5.4.0",
    "reflect-metadata": "^0.2.2"
  },
  "peerDependencies": {
    "@spraxium/common": "*",
    "@spraxium/core": "*",
    "discord.js": "^14.26.3"
  },
  "devDependencies": {
    "@spraxium/common": "workspace:*",
    "@spraxium/core": "workspace:*",
    "@types/node": "^22.0.0",
    "discord.js": "^14.26.3",
    "tsdown": "^0.12.0",
    "typescript": "^5.7.0"
  },
  "files": ["dist"],
  "license": "Apache-2.0"
}
